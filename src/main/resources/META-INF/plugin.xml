<idea-plugin>
    <id>com.github.rabbameghana.codebaseautocompleteplugin</id>
    <name>Context-Aware Multi-File Autocomplete</name>
    <vendor>Codebase Autocomplete</vendor>
    <description>RAG-powered codebase-aware autocomplete using Groq</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <completion.contributor
            language="any"
            implementationClass="com.github.rabbameghana.codebaseautocompleteplugin.CodebaseCompletionProvider"/>
    </extensions>
</idea-plugin>
